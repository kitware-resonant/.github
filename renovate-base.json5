{
  // Base Renovate preset for all Resonant repos (Python/uv and npm).
  // Shared settings inherited by both library and project presets.
  // Do not extend this directly — use renovate-library.json5 or renovate-project.json5.
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:biomeVersions",
    "schedule:weekly",
  ],

  // Wait 3 days before suggesting updates to reduce supply chain risk.
  // Security updates bypass this and are raised immediately.
  // Automatically open a PR when Renovate deprecates config options.
  "configMigration": true,

  "minimumReleaseAge": "3 days",

  "lockFileMaintenance": {
    "enabled": true,
  },

  // Separate each major update for individual review.
  "separateMultipleMajor": true,

  "packageRules": [
    // Group all non-major updates into a single PR.
    // Avoid group:all — it bundles major updates with minor/patch, making it
    // impossible to review and merge them independently. If a major update
    // fails CI, it blocks all the safe minor/patch updates too.
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
    },
    // Group non-major dev tool updates into their own PR, separate from the
    // main "all non-major" group. "dependency-groups" matches Python (PEP 735),
    // "devDependencies" matches npm. This allows library presets to automerge
    // dev tools independently. Major dev tool updates get their own PRs
    // via the root-level separateMultipleMajor setting.
    {
      "matchDepTypes": ["dependency-groups", "devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "dev dependencies",
      "groupSlug": "dev-deps",
    },
    // django-stubs-ext is a runtime dependency that must stay in sync with
    // django-stubs (dev dependency) for patch updates too.
    {
      "matchPackageNames": ["django-stubs-ext"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "groupName": "dev dependencies",
      "groupSlug": "dev-deps",
    },
    // Django minor versions are significant, so pull major+minor out of the
    // "all non-major" group into their own PR. Group with django-stubs and
    // django-stubs-ext since stubs major.minor tracks Django's version.
    // Patch updates are independent and stay in their default groups.
    {
      "matchPackageNames": ["django", "django-stubs", "django-stubs-ext"],
      "matchUpdateTypes": ["major", "minor"],
      "groupName": "django",
    },
    // Group all non-major @biomejs/biome updates together (npm devDependencies,
    // peerDependencies, and biome.jsonc schema from customManagers:biomeVersions).
    // Matching by package name ensures all three stay in a single PR.
    {
      "matchPackageNames": ["@biomejs/biome"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "dev dependencies",
      "groupSlug": "dev-deps",
    },
    // .python-version: use "docker" versioning so "3.12" stays "3.12" (not
    // "3.12.0" or "3.12.11"). Override the default PR title ("python Docker
    // tag") to say "Python version". Remind to update requires-python.
    {
      "matchManagers": ["pyenv"],
      "versioning": "docker",
      "groupName": "Python version",
      "commitMessageTopic": "Python version",
      "prBodyNotes": [
        "**Remember:** also update `requires-python` in `pyproject.toml` to match the new Python version.",
      ],
    },
    // Disable required_version updates in Terraform, as it's only a compatibility
    // constraint and tight bounds make runtime compatibility difficult.
    {
      "matchManagers": ["terraform"],
      "matchDepNames": ["hashicorp/terraform"],
      "enabled": false,
    }
  ],
}
