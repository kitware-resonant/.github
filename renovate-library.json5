{
  // Renovate preset for Resonant libraries (Python/uv and npm).
  //
  // Libraries use loose lower bounds (>= in Python, ^ in npm) for wide
  // consumer compatibility. Renovate only updates the lock file for in-range
  // releases and proposes manifest changes only for out-of-range (major) updates.
  //
  // Usage in your repo's .github/renovate.json5:
  //   { "extends": ["github>kitware-resonant/.github:renovate-library.json5"] }
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>kitware-resonant/.github:renovate-base.json5",
    "schedule:weekly",
  ],

  "lockFileMaintenance": {
    // First Monday of the month, before 4am.
    "schedule": ["* 0-3 * * 1#1"],
  },

  // "update-lockfile" is the key choice for libraries:
  // - In-range updates: only updates the lock file, leaves the manifest untouched
  // - Out-of-range updates: updates both the manifest and lock file
  // For npm, this is already the default ("auto" -> "update-lockfile").
  // For pep621, "auto" -> "replace", which may not create lock-only PRs for
  // in-range releases. Setting this explicitly ensures both ecosystems get
  // lock-only PRs for every in-range direct dependency update.
  "rangeStrategy": "update-lockfile",

  "packageRules": [
    // .python-version: for libraries, keep at the oldest supported Python.
    // - separateMultipleMinor: one PR per minor (3.13, 3.14) for incremental bumps
    // - dependencyDashboardApproval: no automatic PRs, approve from Dashboard
    {
      "matchManagers": ["pyenv"],
      "separateMultipleMinor": true,
      "dependencyDashboardApproval": true,
    },
  ],
}
